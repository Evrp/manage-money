{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "dist"
      }
    }
  ],
  "functions": {
    "apps/api/src/main.ts": {
      "includeFiles": "packages/shared/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/src/main.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/apps/web/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-budget-check",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/monthly-summary",
      "schedule": "0 1 1 * *"
    }
  ]
}
